{
  "name": "sofa-recolor-tool",
  "version": "1.0.0",
  "private": true,
  "description": "Batch recolor a base sofa PNG to leather swatch colors (deterministic, no AI).",
  "type": "module",
  "scripts": {
    "preview": "node render-sofas.js --currant",
    "render": "node render-sofas.js --all",
    "test-colors": "node render-sofas.js --test-colors",
    "manifest": "node build-manifest.js",
    "serve": "node build-manifest.js && node serve-preview.js"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "sharp": "^0.33.5"
  }
}
